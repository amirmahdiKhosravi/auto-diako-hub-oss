# =============================================================================
# Auto Diako Hub — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_or_anon_key

# --- LLM Provider ---
# Choose "openai" or "gemini" for description generation
LLM_PROVIDER=openai

# --- OpenAI (required when LLM_PROVIDER=openai, always required for embeddings) ---
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Google Gemini (required when LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# --- Facebook Catalog / Dealership ---
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEALER_STREET_ADDRESS=123 Main St

# --- Default Location (used as fallback in Facebook Catalog feed) ---
NEXT_PUBLIC_DEFAULT_CITY=Your City
NEXT_PUBLIC_DEFAULT_REGION=Your State/Province
NEXT_PUBLIC_DEFAULT_COUNTRY=US
NEXT_PUBLIC_DEFAULT_LATITUDE=40.7128
NEXT_PUBLIC_DEFAULT_LONGITUDE=-74.0060
